{
  "name": "@kyrra/shared",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./schemas/*": "./src/schemas/*.ts",
    "./rules/*": "./src/rules/*.ts"
  },
  "scripts": {
    "lint": "eslint --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@kyrra/tsconfig": "workspace:*",
    "typescript": "5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
